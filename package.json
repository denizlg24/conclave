{
	"name": "conclave",
	"version": "0.1.0",
	"description": "Multi-agent orchestration platform with role-specialized AI workers",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
